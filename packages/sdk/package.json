{
  "name": "kalguard-sdk",
  "version": "1.0.2",
  "description": "KalGuard SDK - one-line secure integration for AI agents (prompt check, tool check)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "kalguard-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "kalguard",
    "kalguard-sdk",
    "ai-agent",
    "security",
    "prompt-firewall",
    "tool-mediation",
    "policy",
    "zero-trust",
    "llm",
    "sdk"
  ],
  "homepage": "https://infrarix.github.io/kalguard/",
  "bugs": {
    "url": "https://github.com/infrarix/kalguard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infrarix/kalguard.git",
    "directory": "packages/sdk"
  },
  "author": "KalGuard Contributors"
}
