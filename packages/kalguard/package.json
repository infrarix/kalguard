{
  "name": "kalguard",
  "version": "1.1.1",
  "description": "KalGuard - AI Agent Runtime Security Platform. Install this for the SDK (recommended entry point for agents).",
  "author": "Infrarix",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "kalguard-core": "workspace:*",
    "kalguard-sdk": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "kalguard",
    "ai",
    "ai-agent",
    "agent",
    "agent-security",
    "security",
    "runtime",
    "prompt-firewall",
    "prompt-injection",
    "tool-mediation",
    "policy",
    "zero-trust",
    "llm",
    "llmops"
  ],
  "homepage": "https://infrarix.github.io/kalguard/",
  "bugs": {
    "url": "https://github.com/infrarix/kalguard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infrarix/kalguard.git",
    "directory": "packages/kalguard"
  }
}
